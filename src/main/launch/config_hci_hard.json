    "feature_types": {
        "alkane_gas_flame": {
            "type": "task",
            "context_analysis": "The term 'alkane_gas_flame' refers to a flame produced by the combustion of alkane gases. This involves a hazardous scenario related to combustion, which aligns with the task definition emphasizing specific actions that need to be carried out in emergency or dangerous situations.",
            "subtask_gen_analysis": "To handle the hazardous scenario of an alkane gas flame, we need a combination of skills aimed at controlling the source of combustion, suppressing the fire, and ensuring safety. The key is to first inspect the situation to gather critical information about the gas source and surrounding risks. Next, operating valves or switches can help control the flow of alkane gas, reducing the fuel supply. Suppression techniques like liquid spray (using water or foam) will cool the flames and block oxygen, while monitoring ensures that the fire is fully extinguished and no hazards remain. Cleanup may also be necessary to address residual risks.",
            "dep_task_types": [],
            "basic_required_skills": [
                "inspect",
                "operate",
                "liquid_spray",
                "monitor"
            ],
            "schemes": {
                "scheme_1": {
