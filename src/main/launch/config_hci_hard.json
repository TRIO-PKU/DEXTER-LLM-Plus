        "valve": {
            "type": "resource",
            "description": "阀门",
            "context_analysis": "A 'valve' is a mechanical device used to control the flow of liquids or gases. In emergency scenarios, operating valves is essential for isolating hazards and stopping the spread of dangerous substances."
        },
        "switch": {
            "type": "resource",
            "description": "电闸",
            "context_analysis": "A 'switch' is an electrical device used to open or close circuits. In hazardous situations, switches are operated to cut off power and reduce the risk of electrical fires or shocks."
        },
        "water": {
            "type": "resource",
            "description": "水",
            "context_analysis": "'Water' is a common extinguishing agent used to cool fires, dilute hazardous substances, and provide a barrier against heat. It is essential in many fire suppression and protection tasks."
        },
        "foam": {
            "type": "resource",
            "description": "泡沫",
            "context_analysis": "'Foam' is a fire suppression agent that forms a barrier over flammable liquids, cutting off oxygen and preventing re-ignition. It is especially useful for liquid fires."
        },
        "activated_carbon": {
            "type": "resource",
            "description": "活性炭",
            "context_analysis": "'Activated carbon' is a material used to adsorb hazardous gases and chemicals, aiding in containment and cleanup during chemical spills or leaks."
        },
        "asbestos_felt": {
            "type": "resource",
            "description": "石棉毡",
            "context_analysis": "'Asbestos felt' is a heat-resistant material used to isolate and suppress fires, especially in high-temperature or chemical fire scenarios."
        },
        "oxygen": {
            "type": "resource",
            "description": "氧气",
            "context_analysis": "'Oxygen' is essential for life support and medical rescue, especially for individuals exposed to toxic gases or suffering from respiratory distress."
        },
        "metal_net": {
            "type": "resource",
            "description": "金属网",
            "context_analysis": "'Metal net' is used as a protective barrier to isolate hazards, contain debris, or prevent the spread of fire in industrial settings."
        },
        "antidote": {
            "type": "resource",
            "description": "解毒剂",
            "context_analysis": "'Antidote' refers to substances administered to counteract the effects of poisoning, playing a critical role in medical rescue operations."
        }
    },
