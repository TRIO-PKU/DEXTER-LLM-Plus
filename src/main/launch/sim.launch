<launch>
    <!-- Map Config -->
    <arg name="map_name" value="Factory"/>
    <arg name="map_size_x" value="80.0"/>
    <arg name="map_size_y" value="32.0"/>
    <arg name="map_size_z" value="10.0"/>

    <!-- Robot Config -->
    <arg name="odom_topic" value="visual_slam/odom" />

    <include file="$(find ego_planner)/launch/run_in_sim.launch">
        <arg name="drone_id" value="1"/>

        <arg name="init_x" value="-12.0"/>
        <arg name="init_y" value="-12.0"/>
        <arg name="init_z" value="0.3"/>

        <arg name="map_size_x" value="$(arg map_size_x)"/>
        <arg name="map_size_y" value="$(arg map_size_y)"/>
        <arg name="map_size_z" value="$(arg map_size_z)"/>
        <arg name="odom_topic" value="$(arg odom_topic)"/>
    </include>

    <include file="$(find ego_planner)/launch/run_in_sim.launch">
        <arg name="drone_id" value="2"/>

        <arg name="init_x" value="-14.0"/>
        <arg name="init_y" value="-12.0"/>
        <arg name="init_z" value="0.3"/>

        <arg name="map_size_x" value="$(arg map_size_x)"/>
        <arg name="map_size_y" value="$(arg map_size_y)"/>
        <arg name="map_size_z" value="$(arg map_size_z)"/>
        <arg name="odom_topic" value="$(arg odom_topic)"/>
    </include>

    <include file="$(find ego_planner)/launch/run_in_sim.launch">
        <arg name="drone_id" value="3"/>

        <arg name="init_x" value="-16.0"/>
        <arg name="init_y" value="-12.0"/>
        <arg name="init_z" value="0.3"/>

        <arg name="map_size_x" value="$(arg map_size_x)"/>
        <arg name="map_size_y" value="$(arg map_size_y)"/>
        <arg name="map_size_z" value="$(arg map_size_z)"/>
        <arg name="odom_topic" value="$(arg odom_topic)"/>
    </include>

    <include file="$(find ego_planner)/launch/run_in_sim.launch">
        <arg name="drone_id" value="4"/>

        <arg name="init_x" value="-18.0"/>
        <arg name="init_y" value="-12.0"/>
        <arg name="init_z" value="0.3"/>

        <arg name="map_size_x" value="$(arg map_size_x)"/>
        <arg name="map_size_y" value="$(arg map_size_y)"/>
        <arg name="map_size_z" value="$(arg map_size_z)"/>
        <arg name="odom_topic" value="$(arg odom_topic)"/>
    </include>

    <include file="$(find ego_planner)/launch/run_in_sim.launch">
        <arg name="drone_id" value="101"/>

        <arg name="init_x" value="-20.0"/>
        <arg name="init_y" value="-12.0"/>
        <arg name="init_z" value="0.3"/>

        <arg name="map_size_x" value="$(arg map_size_x)"/>
        <arg name="map_size_y" value="$(arg map_size_y)"/>
        <arg name="map_size_z" value="$(arg map_size_z)"/>
        <arg name="odom_topic" value="$(arg odom_topic)"/>
    </include>

</launch>